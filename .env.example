# ── Telegram ────────────────────────────────────────────────
# @BotFather 에서 발급받은 봇 토큰
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTuVwxyZ
# 메시지를 받을 chat id (개인/그룹/채널). @userinfobot 으로 확인 가능
TELEGRAM_CHAT_ID=123456789

# ── 스크리닝 파라미터 (선택) ──────────────────────────────────
# 추세 필터용 장기선
MA_LONG=200
# 골든크로스 단기/장기선
MA_FAST=100
MA_SLOW=150
# 골든크로스를 "최근 N영업일 이내 발생"으로 인정 (1 = 당일만)
GOLDEN_CROSS_LOOKBACK=1
# 이동평균 방식: sma | ema
MA_TYPE=sma
# 대상 시장 (쉼표구분): KOSPI,KOSDAQ
MARKETS=KOSPI,KOSDAQ
# 스팩/우선주 제외 여부
EXCLUDE_SPAC=true
EXCLUDE_PREFERRED=true
# 최소 거래대금 필터(원). 0 이면 미적용. 예: 100000000 (1억)
MIN_TRADING_VALUE=0
